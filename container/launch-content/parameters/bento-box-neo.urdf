<?xml version="1.0"?>
<robot name="bento-box-neo" xmlns:xacro="http://ros.org/wiki/xacro">

<!-- Define robot constants -->
  <xacro:property name="base_width" value="0.17"/>
  <xacro:property name="base_length" value="0.32"/>
  <xacro:property name="base_height" value="0.10"/>

  <xacro:property name="wheel_radius" value="0.055"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_zoff" value="0.05"/>

  <xacro:property name="wheel_front_x" value="0.12"/>
  <xacro:property name="wheel_mid_x" value="0.0"/>
  <xacro:property name="wheel_rear_x" value="-0.12"/>

<!-- Robot Base -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="Red">
        <color rgba="0.7 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

<!-- Robot Footprint -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 ${wheel_radius+wheel_zoff}" rpy="0 0 0"/>
  </joint>

<!--  LiDAR  -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.055"/>
      </geometry>
      <material name="Gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>

  <link name="laser_frame">
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.13 0 0.0775" rpy="0 0 0"/>
  </joint>

  <joint name="laser_frame" type="fixed">
    <parent link="lidar_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 0" rpy="0 0 ${pi}"/>
  </joint>

<!-- Arm -->
  <xacro:property name="bottom_part_length" value="0.165"/>
  <xacro:property name="top_part_length" value="0.155"/>
  <xacro:property name="gripper_part_length" value="0.110"/>
  <xacro:property name="parts_width" value="0.066"/>
  <xacro:property name="parts_height" value="0.02"/>
  <xacro:property name="servo_width" value="0.07"/>
  <xacro:property name="servo_height" value="0.01"/>
  <xacro:property name="servo_length" value="0.01"/>

  <link name="arm_base_servo">
    <visual>
      <geometry>
        <box size="${servo_length} ${servo_width} ${servo_height}"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="Magenta">
        <color rgba="1.0 0.0 1.0 1.0"/>
      </material>
    </visual>
  </link>

  <link name="arm_base_link">
    <visual>
      <geometry>
        <box size="${bottom_part_length} ${parts_width} ${parts_height}"/>
      </geometry>
      <origin xyz="${bottom_part_length/2} 0 ${parts_height/2}"/>
      <material name="Gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>

  <link name="arm_elbow_servo">
    <visual>
      <geometry>
        <box size="${servo_length} ${servo_width} ${servo_height}"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="Magenta">
        <color rgba="1.0 0.0 1.0 1.0"/>
      </material>
    </visual>
  </link>

  <link name="arm_elbow_link">
    <visual>
      <geometry>
        <box size="${top_part_length} ${parts_width} ${parts_height}"/>
      </geometry>
      <origin xyz="${top_part_length/2} 0 ${servo_height}"/>
      <material name="Gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>

  <link name="arm_wrist_servo">
    <visual>
      <geometry>
        <box size="${servo_length} ${servo_width} ${servo_height}"/>
      </geometry>
      <origin xyz="0 0 ${parts_height/2}"/>
      <material name="Magenta">
        <color rgba="1.0 0.0 1.0 1.0"/>
      </material>
    </visual>
  </link>

  <link name="arm_wrist_link">
    <visual>
      <geometry>
        <box size="${gripper_part_length} ${parts_width} ${parts_height}"/>
      </geometry>
      <origin xyz="${gripper_part_length/2} 0 0"/>
      <material name="Gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>


  <joint name="arm_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_servo"/>
    <origin xyz="-0.13 0 0.05" rpy="0 0 0"/>
  </joint>

  <joint name="arm_base_joint" type="revolute">
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="0.0" upper="3.7692" velocity="0.5"/>
    <origin rpy="0 ${pi} 0" xyz="0 0 0"/>
    <parent link="arm_base_servo"/>
    <child link="arm_base_link"/>
  </joint>

  <joint name="arm_base_link_to_elbow_servo" type="fixed">
    <origin rpy="0 0 ${pi}" xyz="${bottom_part_length} 0 ${parts_height}"/>
    <parent link="arm_base_link"/>
    <child link="arm_elbow_servo"/>
  </joint>

  <joint name="arm_elbow_joint" type="revolute">
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="0.0" upper="3.7692" velocity="0.5"/>
    <origin rpy="0 ${pi} 0" xyz="0 0 0.0"/>
    <parent link="arm_elbow_servo"/>
    <child link="arm_elbow_link"/>
  </joint>

  <joint name="arm_elbow_link_to_wrist_servo" type="fixed">
    <origin rpy="0 0 ${pi}" xyz="${top_part_length} 0 0"/>
    <parent link="arm_elbow_link"/>
    <child link="arm_wrist_servo"/>
  </joint>

  <joint name="arm_wrist_joint" type="revolute">
    <axis xyz="0 1 0"/>
    <limit effort="1000.0" lower="0.0" upper="3.7692" velocity="0.5"/>
    <origin rpy="0 ${pi} 0" xyz="0 0 ${parts_height/2}"/>
    <parent link="arm_wrist_servo"/>
    <child link="arm_wrist_link"/>
  </joint>

<!-- Wheel macro -->
  <xacro:macro name="wheel" params="prefix x_pos y_reflect">
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="Gray">
          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>
    </link>

    <joint name="${prefix}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_link"/>
      <origin xyz="${x_pos} ${y_reflect*(base_width/2 + wheel_width/2)} ${-wheel_zoff}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- LEFT SIDE -->
  <xacro:wheel prefix="wheel_front_left" x_pos="${wheel_front_x}" y_reflect="1"/>
  <xacro:wheel prefix="wheel_mid_left" x_pos="${wheel_mid_x}" y_reflect="1"/>
  <xacro:wheel prefix="wheel_rear_left" x_pos="${wheel_rear_x}" y_reflect="1"/>

  <!-- RIGHT SIDE -->
  <xacro:wheel prefix="wheel_front_right" x_pos="${wheel_front_x}" y_reflect="-1"/>
  <xacro:wheel prefix="wheel_mid_right" x_pos="${wheel_mid_x}" y_reflect="-1"/>
  <xacro:wheel prefix="wheel_rear_right" x_pos="${wheel_rear_x}" y_reflect="-1"/>

</robot>
